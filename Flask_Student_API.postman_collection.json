{
  "info": {
    "_postman_id": "flask-student-api-collection",
    "name": "Flask Student API",
    "description": "Complete REST API for managing student records with CRUD operations, filtering, and statistics.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Check",
      "item": [
        {
          "name": "API Health Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/health",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Check if the API is running and healthy"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Students - CRUD",
      "item": [
        {
          "name": "Create Student",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alice Brown\",\n  \"department\": \"Computer Science\",\n  \"cgpa\": 3.75,\n  \"email\": \"alice.brown@university.edu\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/students",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students"
              ]
            },
            "description": "Create a new student record with required fields: name, department, cgpa, email"
          },
          "response": []
        },
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students?page=1&per_page=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            },
            "description": "Retrieve all students with pagination"
          },
          "response": []
        },
        {
          "name": "Get Student by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students",
                "1"
              ]
            },
            "description": "Retrieve a single student by ID"
          },
          "response": []
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cgpa\": 3.95,\n  \"department\": \"Electronics\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/students/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students",
                "1"
              ]
            },
            "description": "Update a student record (partial update supported)"
          },
          "response": []
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students/1",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students",
                "1"
              ]
            },
            "description": "Delete a student record"
          },
          "response": []
        }
      ]
    },
    {
      "name": "Students - Filtering",
      "item": [
        {
          "name": "Filter by Department",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students?department=Computer%20Science&page=1&per_page=10",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students"
              ],
              "query": [
                {
                  "key": "department",
                  "value": "Computer Science"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "10"
                }
              ]
            },
            "description": "Retrieve students filtered by department"
          },
          "response": []
        },
        {
          "name": "Filter by CGPA Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students?min_cgpa=3.7&max_cgpa=4.0",
