                {
                  "key": "max_cgpa",
                  "value": "4.0"
                }
              ]
            },
            "description": "Retrieve students within a CGPA range"
          },
          "response": []
        },
        {
          "name": "Search by Name/Email",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students?search=john",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "john"
                }
              ]
            },
            "description": "Search students by name or email"
          },
          "response": []
        },
        {
          "name": "Sort by CGPA (Descending)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students?sort_by=cgpa&sort_order=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students"
              ],
              "query": [
                {
                  "key": "sort_by",
                  "value": "cgpa"
                },
                {
                  "key": "sort_order",
                  "value": "desc"
                }
              ]
            },
            "description": "Retrieve students sorted by CGPA in descending order"
          },
          "response": []
        },
        {
          "name": "Combined Filters",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/students?department=Computer%20Science&min_cgpa=3.5&sort_by=cgpa&sort_order=desc&page=1&per_page=5",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "students"
              ],
              "query": [
                {
                  "key": "department",
                  "value": "Computer Science"
                },
                {
                  "key": "min_cgpa",
                  "value": "3.5"
                },
                {
                  "key": "sort_by",
                  "value": "cgpa"
                },
                {
                  "key": "sort_order",
                  "value": "desc"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "5"
                }
              ]
            },
            "description": "Retrieve students with multiple filters applied"
          },
          "response": []
        }
      ]
    },
